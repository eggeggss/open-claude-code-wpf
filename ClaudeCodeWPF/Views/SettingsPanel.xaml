<Window x:Class="OpenClaudeCodeWPF.Views.SettingsPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenClaudeCodeWPF.ViewModels"
        xmlns:utils="clr-namespace:OpenClaudeCodeWPF.Utils"
        xmlns:mcp="clr-namespace:OpenClaudeCodeWPF.Services.MCP"
        Title="設定" Height="760" Width="640"
        Background="#1E1E1E" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="500" MinHeight="500">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6000"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#CCCCCC"/>
        </Style>
        <Style x:Key="ProviderSep" TargetType="Separator">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="MultiLineBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Courier New"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CaretBrush" Value="#CCCCCC"/>
        </Style>
        <!-- Dark ComboBox for settings (not DynamicResource) -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MaxDropDownHeight" Value="200"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#888888"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,1,6,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="6,3,24,3" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="1">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3C3C3C"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6000"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Value Converters for MCP tab -->
        <utils:NullToVisibilityConverter x:Key="NullToHidden"/>
        <utils:BoolToVisibilityConverter x:Key="BoolToVisible"/>
        <ObjectDataProvider x:Key="McpServerTypes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}"
                            xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="mcp:McpServerType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#141414" Padding="20,10">
            <TextBlock Text="⚙  設定" Foreground="#CCCCCC" FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- TabControl -->
        <TabControl Grid.Row="1" Background="#1E1E1E" BorderThickness="0,1,0,0" BorderBrush="#3E3E42">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#252526"/>
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="#FF6000"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ══ Tab 1: Provider API Keys ══ -->
            <TabItem Header="🔑 供應商 API">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,8,24,24">

                        <!-- Anthropic -->
                        <TextBlock Text="Anthropic" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="AnthropicKeyBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                     Text="{Binding AnthropicKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Separator Style="{StaticResource ProviderSep}"/>

                        <!-- OpenAI -->
                        <TextBlock Text="OpenAI" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="OpenAIKeyBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                     Text="{Binding OpenAIKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Base URL" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="OpenAIBaseBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                     Text="{Binding OpenAIBase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Separator Style="{StaticResource ProviderSep}"/>

                        <!-- Gemini -->
                        <TextBlock Text="Google Gemini" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="GeminiKeyBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                     Text="{Binding GeminiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Separator Style="{StaticResource ProviderSep}"/>

                        <!-- OpenRouter -->
                        <TextBlock Text="OpenRouter" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="OpenRouterKeyBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                     Text="{Binding OpenRouterKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="支援數百種模型，預設 openai/gpt-4o-mini。可在模型選單輸入任意 OpenRouter model ID。"/>
                        <Separator Style="{StaticResource ProviderSep}"/>

                        <!-- Ollama -->
                        <TextBlock Text="Ollama（本地）" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Base URL" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="OllamaBaseBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                     Text="{Binding OllamaBase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="自訂模型清單（一行一個 Model ID，留空則自動偵測或使用預設）"/>
                        <TextBox x:Name="OllamaModelsBox" Style="{StaticResource MultiLineBox}" Height="80"
                                 Text="{Binding OllamaModels, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Separator Style="{StaticResource ProviderSep}"/>

                        <!-- Azure OpenAI -->
                        <TextBlock Text="Azure OpenAI（多節點）" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource HintText}">
                            格式（一行一個節點）：名稱|端點URL|API金鑰|部署名稱|API版本<LineBreak/>
                            例：East US|https://myhub.openai.azure.com|sk-xxx|gpt-4o|2024-02-01
                        </TextBlock>
                        <TextBox x:Name="AzureNodesBox" Style="{StaticResource MultiLineBox}" Height="110"
                                 Text="{Binding AzureNodes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Azure Responses API (GPT-5.x) -->
                        <TextBlock Text="Azure Responses API（GPT-5.x 系列）" Style="{StaticResource SectionHeader}" Margin="0,16,0,0"/>
                        <TextBlock Style="{StaticResource HintText}">
                            格式（一行一個節點）：名稱|端點URL|API金鑰|模型名稱|API版本<LineBreak/>
                            例：GPT-5.1|https://myhub.openai.azure.com|sk-xxx|gpt-5.1-codex-mini|2025-04-01-preview
                        </TextBlock>
                        <TextBox x:Name="AzureResponsesNodesBox" Style="{StaticResource MultiLineBox}" Height="110"
                                 Text="{Binding AzureResponsesNodes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ Tab 2: Model Parameters ══ -->
            <TabItem Header="⚙️ 模型參數">
                <StackPanel Margin="24,16,24,24">

                    <TextBlock Text="推理參數" Style="{StaticResource SectionHeader}"
                               Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Temperature" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="TempSlider" Grid.Column="1"
                                Minimum="0" Maximum="1" TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Temperature, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TempValue" Grid.Column="2"
                                   Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"
                                   Text="{Binding TemperatureDisplay}"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max Tokens" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="MaxTokensBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                 Text="{Binding MaxTokensText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Separator Style="{StaticResource ProviderSep}"/>
                    <TextBlock Text="介面行為" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="串流模式" Style="{StaticResource FieldLabel}"/>
                        <CheckBox x:Name="StreamingCheck" Grid.Column="1"
                                  Foreground="#CCCCCC" FontSize="12"
                                  Content="啟用串流回應" VerticalAlignment="Center"
                                  IsChecked="{Binding StreamingEnabled, Mode=TwoWay}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="語言" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="LanguageCombo" Grid.Column="1"
                                  Style="{StaticResource DarkCombo}"
                                  SelectedValue="{Binding Language, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                          Content="繁體中文" Tag="zh-TW"/>
                            <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                          Content="English" Tag="en"/>
                        </ComboBox>
                    </Grid>

                </StackPanel>
            </TabItem>

            <!-- ══ Tab 3: UI / Theme / Font ══ -->
            <TabItem Header="🎨 介面">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,16,24,24">

                        <TextBlock Text="主題" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                        <WrapPanel Margin="0,0,0,14">
                            <Button x:Name="ThemeBtn_Dark" Tag="Dark"
                                    Content="🌙 深色" Width="90" Height="28" Margin="0,0,6,4"
                                    Background="#3C3C3C" Foreground="#CCCCCC" BorderThickness="0"
                                    Click="ThemeButton_Click"/>
                            <Button x:Name="ThemeBtn_Light" Tag="Light"
                                    Content="☀️ 白色" Width="90" Height="28" Margin="0,0,6,4"
                                    Background="#E0E0E0" Foreground="#1E1E1E" BorderThickness="0"
                                    Click="ThemeButton_Click"/>
                            <Button x:Name="ThemeBtn_ClaudeCode" Tag="ClaudeCode"
                                    Content="🤖 Open Claude Code WPF" Width="120" Height="28"
                                    Background="#FF6000" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="ThemeButton_Click"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource ProviderSep}"/>
                        <TextBlock Text="字體設定" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="字型" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FontFamilyCombo" Grid.Column="1"
                                      Style="{StaticResource DarkCombo}"
                                      SelectedValue="{Binding FontFamily, Mode=TwoWay}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Segoe UI" Tag="Segoe UI"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Microsoft JhengHei UI (推薦)" Tag="Microsoft JhengHei UI"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Yu Gothic UI" Tag="Yu Gothic UI"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Trebuchet MS" Tag="Trebuchet MS"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Calibri" Tag="Calibri"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Candara" Tag="Candara"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Comic Sans MS (輕鬆休閒)" Tag="Comic Sans MS"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Microsoft JhengHei" Tag="Microsoft JhengHei"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Microsoft YaHei" Tag="Microsoft YaHei"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Consolas" Tag="Consolas"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Cascadia Code" Tag="Cascadia Code"/>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}"
                                              Content="Arial" Tag="Arial"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="字體大小" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="FontSizeSlider" Grid.Column="1"
                                    Minimum="10" Maximum="22" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding FontSize, Mode=TwoWay}"
                                    VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="FontSizeValue" Grid.Column="2"
                                       Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"
                                       Text="{Binding FontSizeDisplay}"/>
                        </Grid>

                        <!-- Font preview -->
                        <Border Background="#2A2A2C" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="4" Padding="12,8">
                            <TextBlock x:Name="FontPreview" Foreground="#CCCCCC" TextWrapping="Wrap"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       Text="預覽：The quick brown fox 快速的棕色狐狸 1234567890"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ Tab 4: System Prompt ══ -->
            <TabItem Header="📝 系統提示">
                <Grid Margin="24,16,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="自訂系統提示詞（留空使用預設）"
                               Foreground="#888888" FontSize="11" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1" x:Name="SystemPromptBox"
                             Background="#2D2D30" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" BorderThickness="1"
                             Padding="8" FontSize="12"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             CaretBrush="#CCCCCC"
                             Text="{Binding SystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ══ Tab 5: MCP 伺服器 ══ -->
            <TabItem Header="🔌 MCP 伺服器">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Server List -->
                    <Border Grid.Column="0" BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="McpServerList" Grid.Row="0"
                                     Background="#252526" BorderThickness="0"
                                     ItemsSource="{Binding McpVM.Servers}"
                                     SelectedItem="{Binding McpVM.SelectedServer, Mode=TwoWay}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#37373D"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2D2E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="#EEEEEE"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <Border Background="#3C3F41" CornerRadius="2"
                                                            Padding="3,1" Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding TypeLabel}"
                                                                   FontSize="9" Foreground="#9CDCFE"/>
                                                    </Border>
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{Binding StatusColor}"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="10" Foreground="#888888"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Enable Toggle -->
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      ToolTip="啟用/停用"
                                                      Command="{Binding DataContext.McpVM.ToggleEnabledCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Add button -->
                            <Button Grid.Row="1" Content="＋ 新增伺服器"
                                    Margin="8" Height="28"
                                    Background="#FF6000" Foreground="White" BorderThickness="0"
                                    FontSize="12"
                                    Command="{Binding McpVM.AddNewCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Right: Edit Form -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,12,20,20"
                                    Visibility="{Binding McpVM.EditingServer, Converter={StaticResource NullToHidden}}">

                            <TextBlock Text="{Binding McpVM.FormTitle}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#FF6000" Margin="0,0,0,16"/>

                            <!-- Server Name -->
                            <TextBlock Text="Server Name" Foreground="#9CDCFE" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding McpVM.EditingServer.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}" Margin="0,0,0,12"
                                     ToolTip="此 MCP 伺服器的唯一識別名稱"/>

                            <!-- Server Type -->
                            <TextBlock Text="Server Type" Foreground="#9CDCFE" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="McpTypeCombo"
                                      Margin="0,0,0,12"
                                      Background="#2D2D30" Foreground="#CCCCCC"
                                      BorderBrush="#3E3E42"
                                      ItemsSource="{Binding Source={StaticResource McpServerTypes}}"
                                      SelectedItem="{Binding McpVM.EditingServer.Type, Mode=TwoWay}"/>

                            <!-- Command (Local / STDIO) -->
                            <StackPanel Visibility="{Binding McpVM.EditingServer.IsProcessBased, Converter={StaticResource BoolToVisible}}">
                                <TextBlock Text="Command" Foreground="#9CDCFE" FontSize="11" Margin="0,0,0,4"/>
                                <TextBlock Text="啟動伺服器的命令 (例如: python -m my_server)"
                                           Foreground="#666666" FontSize="10" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding McpVM.EditingServer.Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBox}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- URL (HTTP / SSE) -->
                            <StackPanel Visibility="{Binding McpVM.EditingServer.IsUrlBased, Converter={StaticResource BoolToVisible}}">
                                <TextBlock Text="URL" Foreground="#9CDCFE" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding McpVM.EditingServer.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBox}" Margin="0,0,0,12"
                                         ToolTip="HTTP 或 SSE 端點 URL"/>
                            </StackPanel>

                            <!-- Environment Variables -->
                            <TextBlock Text="Environment Variables" Foreground="#9CDCFE" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="每行一個，格式: KEY=VALUE"
                                       Foreground="#666666" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding McpVM.EditingServer.EnvVarsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"
                                     Height="80" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Margin="0,0,0,12"/>

                            <!-- Tools -->
                            <TextBlock Text="Tools" Foreground="#9CDCFE" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="開放的工具：* 代表全部，或逗號分隔清單"
                                       Foreground="#666666" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding McpVM.EditingServer.Tools, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}" Margin="0,0,0,16"/>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="💾 儲存" Width="80" Height="28" Margin="0,0,8,0"
                                        Background="#FF6000" Foreground="White" BorderThickness="0"
                                        Command="{Binding McpVM.SaveCommand}"/>
                                <Button Content="✖ 取消" Width="70" Height="28" Margin="0,0,8,0"
                                        Background="#3C3C3C" Foreground="#CCCCCC" BorderThickness="0"
                                        Command="{Binding McpVM.CancelCommand}"/>
                                <Button Content="🗑 刪除" Width="70" Height="28" Margin="0,0,16,0"
                                        Background="#6E3C3C" Foreground="#CCCCCC" BorderThickness="0"
                                        Command="{Binding McpVM.DeleteCommand}"/>
                                <Separator Width="1" Background="#3E3E42" Margin="0,0,16,0"/>
                                <Button Content="▶ 連接" Width="70" Height="28" Margin="0,0,8,0"
                                        Background="#2D6A4F" Foreground="White" BorderThickness="0"
                                        Command="{Binding McpVM.ConnectCommand}"/>
                                <Button Content="⏹ 中斷" Width="70" Height="28"
                                        Background="#3C3C3C" Foreground="#CCCCCC" BorderThickness="0"
                                        Command="{Binding McpVM.DisconnectCommand}"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="#141414" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="80" Height="30" Margin="0,0,10,0"
                        Background="#3C3C3C" Foreground="#CCCCCC" BorderThickness="0"
                        Click="CancelButton_Click"/>
                <Button Content="儲存" Width="80" Height="30"
                        Background="#FF6000" Foreground="White" BorderThickness="0"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
