<UserControl x:Class="OpenClaudeCodeWPF.Views.ToolsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PrimaryBgBrush}">

    <UserControl.Resources>
        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="8,12,8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Tool card border -->
        <Style x:Key="ToolCard" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="6,2,6,2"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Tool name text -->
        <Style x:Key="ToolName" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Tool description -->
        <Style x:Key="ToolDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Tool category badge -->
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="4,1,4,1"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🧩 工具 &amp; 技能" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="Medium"
                           VerticalAlignment="Center"/>
                <Button x:Name="RefreshButton" Grid.Column="1" Content="↺" Width="24" Height="24"
                        Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                        FontSize="14" ToolTip="重新整理" Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- Scrollable list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="MainPanel">

                <!-- MCP Tools Section -->
                <TextBlock x:Name="McpHeader" Style="{StaticResource SectionHeader}" Text="🔧 MCP 工具"/>
                <StackPanel x:Name="McpToolsPanel"/>

                <!-- Separator -->
                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="6,8,6,0"/>

                <!-- Skills Section -->
                <DockPanel Margin="8,12,8,4" LastChildFill="True">
                    <Button x:Name="ImportSkillButton" DockPanel.Dock="Right"
                            Content="＋ 上傳" Background="Transparent"
                            BorderThickness="1" BorderBrush="#3C3C3C"
                            Foreground="#909090" FontSize="10" Padding="6,2"
                            Cursor="Hand" ToolTip="上傳自訂技能 (.json 格式)"
                            Click="ImportSkillButton_Click"/>
                    <TextBlock x:Name="SkillsHeader"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Text="⚡ 技能 (0)"/>
                </DockPanel>
                <StackPanel x:Name="SkillsPanel"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
