<UserControl x:Class="OpenClaudeCodeWPF.Views.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SecondaryBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="對話歷史" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="CollapseBtn"
                        Content="◀" Width="22" Height="22"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        FontSize="11" Cursor="Hand" ToolTip="摺疊側欄"
                        Click="CollapseBtn_Click"/>
            </Grid>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1" Margin="8,6" Background="{DynamicResource InputBoxBrush}" CornerRadius="4"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <TextBox x:Name="SearchBox" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}"
                     BorderThickness="0" Padding="8,4" FontSize="12"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Tag="搜尋對話..."/>
        </Border>

        <!-- Session list -->
        <ListBox x:Name="SessionList" Grid.Row="2"
                 Background="Transparent" BorderThickness="0"
                 ItemsSource="{Binding DisplayedSessions}"
                 SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" Cursor="Hand">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1" Text="{Binding UpdatedAt, StringFormat={}{0:MM/dd HH:mm}}"
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource TertiaryBgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource TertiaryBgBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>

