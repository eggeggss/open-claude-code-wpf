<UserControl x:Class="OpenClaudeCodeWPF.Views.ToolOutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PrimaryBgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,6">
            <Grid>
                <TextBlock Text="工具輸出" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="清除" HorizontalAlignment="Right"
                        Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                        FontSize="11" Click="ClearButton_Click"/>
            </Grid>
        </Border>

        <!-- Tool outputs scroll -->
        <ScrollViewer Grid.Row="1" x:Name="OutputScroll" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="OutputPanel" Margin="8"/>
        </ScrollViewer>
    </Grid>
</UserControl>
